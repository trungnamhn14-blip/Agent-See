# Tạo khóa mới tại https://aistudio.google.com/apikey — KHÔNG dùng lại khóa đã lộ.
GOOGLE_API_KEY=

# Chuỗi bí mật ký cookie session (random 32+ ký tự)
AUTH_SECRET=

# URL POST login bài tập Trang Đen (đúng endpoint trong đề bài, có /login ở cuối).
# Bắt buộc nếu học viên đăng nhập bằng hex 32 ký tự (không phải hex admin).
# Ví dụ:
# TRANG_DEN_LOGIN_URL=https://trangden.vn/agentsee/api/bai-tap/3147/ee1e8daa7069730fa9a25606f607f9cb/tuan-1/bai-6/cau-6/login

# Tuỳ chọn: hex 32 ký tự của chủ bài → luôn admin (mặc định = token trong URL bài mẫu).
# AGENTSEE_ADMIN_HEX=ee1e8daa7069730fa9a25606f607f9cb

# Tuỳ chọn. Nên để trống: server gọi ListModels và chỉ dùng model thật sự mở cho key của bạn.
# GEMINI_MODEL=
