# Tạo khóa mới tại https://aistudio.google.com/apikey — KHÔNG dùng lại khóa đã lộ.
GOOGLE_API_KEY=

# Mật khẩu đăng nhập web (đặt mạnh, trùng với giá trị trên Vercel → Environment Variables)
APP_PASSWORD=

# Chuỗi bí mật ký cookie (random 32+ ký tự)
AUTH_SECRET=

# Tuỳ chọn. Nên để trống: server gọi ListModels và chỉ dùng model thật sự mở cho key của bạn.
# Nếu set, model này được thử trước (có thể gây 429 nếu quota = 0), sau đó vẫn thử các model còn lại từ API.
# GEMINI_MODEL=
