# Tạo khóa mới tại https://aistudio.google.com/apikey — KHÔNG dùng lại khóa đã lộ.
GOOGLE_API_KEY=

# Mật khẩu đăng nhập web (đặt mạnh, trùng với giá trị trên Vercel → Environment Variables)
APP_PASSWORD=

# Chuỗi bí mật ký cookie (random 32+ ký tự)
AUTH_SECRET=

# Tuỳ chọn. Để trống = ưu tiên gemini-1.5-flash. Một số model (vd. gemini-2.0-flash) có thể quota free = 0;
# code sẽ tự fallback sang gemini-1.5-flash nếu gặp 429 / model lỗi.
# GEMINI_MODEL=
